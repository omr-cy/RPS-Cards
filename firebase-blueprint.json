{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Stores player progression, coins, and themes.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "coins": { "type": "integer" },
        "purchasedThemes": { "type": "array", "items": { "type": "string" } },
        "equippedTheme": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "coins", "purchasedThemes", "equippedTheme", "createdAt", "updatedAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User documents tied to Firebase Auth UID"
    }
  }
}
