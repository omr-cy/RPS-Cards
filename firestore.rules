rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
       allow read, write: if false; 
    }

    // Primitive Helpers
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'coins', 'purchasedThemes', 'equippedTheme', 'createdAt', 'updatedAt'])
        && data.uid is string && data.uid.size() <= 128
        && data.coins is number
        && data.purchasedThemes is list && data.purchasedThemes.size() <= 50 // Bounded array
        && (data.purchasedThemes.size() == 0 || data.purchasedThemes[0] is string)
        && data.equippedTheme is string && data.equippedTheme.size() <= 100
        && ( !('displayName' in data) || (data.displayName is string && data.displayName.size() <= 50) );
    }

    // Users Collection
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false; // No blanket listing of users

      allow create: if isOwner(userId) 
                    && isValidId(userId)
                    && isValidUser(incoming())
                    && incoming().uid == request.auth.uid
                    && incoming().keys().size() == (('displayName' in incoming()) ? 7 : 6)
                    && incoming().createdAt == request.time
                    && incoming().updatedAt == request.time
                    && incoming().coins >= 0; // Baseline coins

      allow update: if isOwner(userId) 
                    && isValidId(userId)
                    && isValidUser(incoming())
                    && incoming().uid == existing().uid
                    && incoming().createdAt == existing().createdAt
                    && incoming().updatedAt == request.time
                    && (
                      // Only allow specific updates (e.g., buying a theme, changing equipped theme, updating name and coins)
                      incoming().diff(existing()).affectedKeys().hasOnly(['coins', 'purchasedThemes', 'equippedTheme', 'displayName', 'updatedAt'])
                    );

      allow delete: if false; // Deletion handled by server/admin
    }
  }
}
